{
  "name": "csmp-iii-studio",
  "version": "2.0.0",
  "description": "CSMP III Continuous System Modeling Program",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win",
    "make": "electron-builder build --win --x64"
  },
  "build": {
    "appId": "com.bishnu.csmp-iii-studio",
    "productName": "CSMP III Studio",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "license": "build/license.txt"
    }
  },
  "author": "Bishnu",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "jimp": "^0.22.10",
    "png-to-ico": "^3.0.1"
  }
}
